{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Adzrvr Adapter Params",
  "description": "A schema which validates params accepted by the Adzrvr adapter",
  "type": "object",
  "properties": {
    "placement_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique placement identifier"
    },
    "publisher_id": {
      "type": "string",
      "description": "Publisher identifier (optional)"
    }
  },
  "required": [
    "placement_id"
  ]
}
